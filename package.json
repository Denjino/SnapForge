{
  "name": "snapforge",
  "version": "1.0.0",
  "description": "Bulk URL screenshot tool with viewport presets",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:all": "npm run build && electron-builder -mw"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "^14.2.0",
    "playwright": "^1.58.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.snapforge.app",
    "productName": "SnapForge",
    "artifactName": "SnapForge-${version}-${os}-${arch}.${ext}",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "package.json",
      {
        "from": ".next/standalone",
        "to": ".next/standalone",
        "filter": ["**/*"]
      },
      {
        "from": ".next/static",
        "to": ".next/standalone/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": ".next/standalone/public",
        "filter": ["**/*"]
      },
      "node_modules/playwright/**/*",
      "node_modules/playwright-core/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "SnapForge-${version}-portable.exe"
    }
  }
}
