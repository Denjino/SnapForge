<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Electron apps need JIT for V8 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- V8 writes-then-executes memory pages -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Electron reads DYLD_* / ELECTRON_RUN_AS_NODE / PATH at spawn time -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Required because SnapForge spawns the Next.js standalone server
         as a child Node process using process.execPath; that child loads
         Sharp's native .node files, which aren't loaded by the main
         Electron framework. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Playwright installs Chromium at runtime into userData; spawning
         that binary needs this on hardened runtime. -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>
</dict>
</plist>
